{
  "metadata": {
    "description": "v4.6 优化版 — 统一梯度 + Interface退火 + 提升物理权重",
    "based_on": "v4.6-standard.json"
  },
  "model": {
    "input_format": "triplet",
    "hidden_phi": [128, 128, 64, 32],
    "hidden_vel": [64, 64, 32],
    "use_fourier": true
  },
  "stage1_eta_tutor": true,
  "training": {
    "epochs": 60000,
    "batch_size": 4096,
    "learning_rate": 0.0003,
    "min_lr": 1e-06,
    "gradient_clip": 1.0,
    "stage1_epochs": 1500,
    "stage2_epochs": 4000,
    "stage3_epochs": 60000,
    "early_stop_patience": 60000,
    "warmup_epochs": 500,
    "volume_n_vol": 8000,
    "volume_base_weight": 2000.0,
    "stage1_tutor_min_factor": 0.0,
    "stage1_tutor_anneal_span": 10000,
    "continuity_transition_weight": 2000.0,
    "use_lbfgs": true,
    "lbfgs_iter": 3000,
    "resample_interval": 0
  },
  "eval": {
    "aperture_phi0": 0.3,
    "aperture_eps": 0.05
  },
  "physics": {
    "interface_weight": 500.0,
    "ic_weight": 300.0,
    "bc_weight": 80.0,
    "continuity_weight": 5.0,
    "vof_weight": 8.0,
    "ns_weight": 2.0,
    "surface_tension_weight": 0.5,
    "sharpening_weight": 1.0,
    "explicit_volume_weight": 50.0,
    "electrowetting_weight": 0.0,
    "laplace_pressure_weight": 0.1,
    "sidewall_contact_angle": 5.0,
    "interface_energy_weight": 0.5,
    "wall_wetting_weight": 1.0,
    "temporal_smoothness_weight": 0.5,
    "dielectric_charge_weight": 0.5,
    "contact_line_dynamics_weight": 0.5,
    "top_boundary_weight": 0.1
  }
}
